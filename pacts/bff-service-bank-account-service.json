{
  "consumer": {
    "name": "bff-service"
  },
  "interactions": [
    {
      "description": "a GET request to fetch all accounts",
      "providerState": "bank accounts exist",
      "request": {
        "method": "GET",
        "path": "/accounts"
      },
      "response": {
        "body": [
          {
            "balance": 2500.75,
            "currency": "USD",
            "id": "acc-123",
            "user_id": "test-user-123"
          }
        ],
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "$.body": {
            "match": "type",
            "min": 1
          },
          "$.body[*].balance": {
            "match": "decimal"
          }
        },
        "status": 200
      }
    },
    {
      "description": "a POST request to create an account",
      "providerState": "a request to create a bank account",
      "request": {
        "body": {
          "balance": 100,
          "currency": "THB",
          "user_id": "test-user-123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "$.body.balance": {
            "match": "type"
          }
        },
        "method": "POST",
        "path": "/accounts"
      },
      "response": {
        "body": {
          "balance": 100,
          "currency": "THB",
          "id": "generated-account-id",
          "user_id": "test-user-123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "$.body.balance": {
            "match": "type"
          },
          "$.body.id": {
            "match": "type"
          }
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-go": {
      "version": "2.5.1"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "mockserver": "1.2.16",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "2.0.0"
    }
  },
  "provider": {
    "name": "bank-account-service"
  }
}