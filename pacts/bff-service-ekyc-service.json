{
  "consumer": {
    "name": "bff-service"
  },
  "interactions": [
    {
      "description": "a POST request to verify eKYC",
      "providerState": "customer cust-123 submits identity verification",
      "request": {
        "body": {
          "customer_id": "cust-123",
          "document_type": "national_id",
          "full_name": "Jane Doe",
          "national_id": "1100200300401"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/ekycs/verify"
      },
      "response": {
        "body": {
          "confidence_score": 0.98,
          "customer_id": "cust-123",
          "document_type": "national_id",
          "full_name": "Jane Doe",
          "id": "ekyc-789",
          "national_id": "1100200300401",
          "status": "APPROVED"
        },
        "headers": {
          "Content-Type": "application/json",
          "Location": "/ekycs/ekyc-789"
        },
        "matchingRules": {
          "$.body.confidence_score": {
            "match": "type"
          },
          "$.body.id": {
            "match": "type"
          },
          "$.headers.Location": {
            "match": "type"
          }
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-go": {
      "version": "2.5.1"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "mockserver": "1.2.16",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "2.0.0"
    }
  },
  "provider": {
    "name": "ekyc-service"
  }
