{
  "consumer": {
    "name": "bff-service"
  },
  "interactions": [
    {
      "description": "a GET request to fetch user details",
      "providerState": "a user with ID test-user-123 exists",
      "request": {
        "method": "GET",
        "path": "/users/test-user-123"
      },
      "response": {
        "body": {
          "email": "jane.doe@example.com",
          "id": "test-user-123",
          "name": "Jane Doe",
          "phone": "+66800000001",
          "status": "active"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "status": 200
      }
    },
    {
      "description": "a POST request to create a user",
      "providerState": "a request to create a user",
      "request": {
        "body": {
          "email": "john.smith@example.com",
          "name": "John Smith",
          "phone": "+66800000002"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/users"
      },
      "response": {
        "body": {
          "email": "john.smith@example.com",
          "id": "generated-user-id",
          "name": "John Smith",
          "phone": "+66800000002",
          "status": "active"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "$.body.id": {
            "match": "type"
          }
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-go": {
      "version": "2.5.1"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "mockserver": "1.2.16",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "2.0.0"
    }
  },
  "provider": {
    "name": "user-service"
  }
}