{
  "consumer": {
    "name": "bff-service"
  },
  "interactions": [
    {
      "description": "a POST request to initiate a fund transfer",
      "providerState": "accounts acc-123 and acc-456 exist",
      "request": {
        "body": {
          "amount": 500,
          "currency": "THB",
          "source_account_id": "acc-123",
          "target_account_id": "acc-456"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "$.body.amount": {
            "match": "type"
          }
        },
        "method": "POST",
        "path": "/transfers"
      },
      "response": {
        "body": {
          "amount": 500,
          "currency": "THB",
          "id": "txn-999",
          "source_account_id": "acc-123",
          "status": "COMPLETED",
          "target_account_id": "acc-456"
        },
        "headers": {
          "Content-Type": "application/json",
          "Location": "/transfers/txn-999"
        },
        "matchingRules": {
          "$.body.amount": {
            "match": "type"
          },
          "$.body.id": {
            "match": "type"
          },
          "$.headers.Location": {
            "match": "type"
          }
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-go": {
      "version": "2.5.1"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "mockserver": "1.2.16",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "2.0.0"
    }
  },
  "provider": {
    "name": "transfer-service"
  }
}