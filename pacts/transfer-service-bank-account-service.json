{
  "consumer": {
    "name": "transfer-service"
  },
  "interactions": [
    {
      "description": "a request to verify account status",
      "providerState": "source account acc-123 exists with sufficient balance",
      "request": {
        "method": "GET",
        "path": "/accounts"
      },
      "response": {
        "body": [
          {
            "balance": 2500.75,
            "currency": "USD",
            "id": "acc-123",
            "user_id": "test-user-123"
          }
        ],
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "$.body": {
            "match": "type",
            "min": 1
          },
          "$.body[*].balance": {
            "match": "decimal"
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-go": {
      "version": "2.5.1"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "mockserver": "1.2.16",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "2.0.0"
    }
  },
  "provider": {
    "name": "bank-account-service"
  }
}