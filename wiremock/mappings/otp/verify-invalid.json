{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/otp/verify",
    "headers": {
      "Mock-Scenario": { "contains": "OTP:INVALID" }
    }
  },
  "response": {
    "status": 400,
    "jsonBody": {
      "error": "invalid_otp"
    },
    "headers": {
      "Content-Type": "application/json",
      "Mock-ID": "{{request.headers.Mock-ID}}"
    },
    "transformers": ["response-template"]
  }
}
