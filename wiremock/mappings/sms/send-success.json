{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/sms/send",
    "headers": {
      "Mock-Scenario": { "contains": "SMS:SUCCESS" }
    }
  },
  "response": {
    "status": 200,
    "jsonBody": {
      "status": "sent",
      "id": "mock-sms-id"
    },
    "headers": {
      "Content-Type": "application/json",
      "Mock-ID": "{{request.headers.Mock-ID}}"
    },
    "transformers": ["response-template"]
  }
}
